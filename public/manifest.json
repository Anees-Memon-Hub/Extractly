{
  "manifest_version": 3,
  "name": "Extractly",
  "description": "Extract text from screenshots and images using OCR.",
  "version": "1.0.0",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Extractly"
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}